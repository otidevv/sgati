# ══════════════════════════════════════════════════════════════════════
#  Apache Guacamole — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════════════════════════════

# ── Base de datos de Guacamole (PostgreSQL dedicado) ──────────────────
GUAC_DB=guacamole_db
GUAC_DB_USER=guacamole
GUAC_DB_PASSWORD=cambia_esta_contrasena_segura

# ── Puertos expuestos en el host ──────────────────────────────────────
# Nginx (proxy principal — accede desde aquí)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Guacamole directo (opcional, solo si no usas nginx)
# GUAC_PORT=8080

# ── Dominio o IP del servidor ─────────────────────────────────────────
# Se usa en nginx.conf para el server_name
GUAC_SERVER_NAME=guacamole.unamad.local
# Si accedes por IP directa, pon la IP aquí:
# GUAC_SERVER_NAME=192.168.254.X
